# ============================================
# ITOps Platform - 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填写实际值
# Docker Compose 会自动读取 .env 文件

# ============================================
# 应用配置
# ============================================
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=1
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# 数据库配置 (MySQL)
# ============================================
ITOPS_DB_TYPE=mysql
ITOPS_DB_HOST=localhost
ITOPS_DB_PORT=3306
ITOPS_DB_USER=root
ITOPS_DB_PASSWORD=your-db-password
ITOPS_DB_NAME=itops_platform

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# 监控配置
# ============================================
MONITORING_ENABLED=true

# ============================================
# AI 配置 (Ollama)
# ============================================
AI_ENABLED=true
AI_MODEL=qwen2.5:7b

# ============================================
# 告警通知配置 (可选)
# ============================================
# 钉钉
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
DINGTALK_SECRET=YOUR_SECRET

# 飞书
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK
FEISHU_SECRET=YOUR_SECRET

# 邮件
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
FROM_ADDRESS=alerts@example.com

# Zabbix (可选)
ZABBIX_USER=Admin
ZABBIX_PASSWORD=your-zabbix-password

# ============================================
# MinIO 对象存储 (可选)
# ============================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ============================================
# JWT / Session 安全配置
# ============================================
JWT_SECRET_KEY=your-jwt-secret-key
SESSION_SECRET_KEY=your-session-secret-key

# ============================================
# OpenAI API (可选，用于云端 AI)
# ============================================
OPENAI_API_KEY=your-openai-api-key
